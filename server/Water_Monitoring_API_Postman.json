{
  "info": {
    "name": "Aquora Smart Water Meter API",
    "description": "Koleksi API untuk skripsi sistem monitoring air",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Fitur Masuk (Login)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@aquora.com\",\n  \"password\": \"password123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "2. Fitur Keluar (Logout)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/auth/logout",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "logout"
          ]
        }
      }
    },
    {
      "name": "3. Fitur Pendaftaran Perangkat (Opsional/Pendukung)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Meteran Apartemen 101\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/v1/devices",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "devices"
          ]
        }
      }
    },
    {
      "name": "4. Fitur Mengirim Data Sensor (Telemetri)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "x-api-key",
            "value": "WaterMon_Secret_2026",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"deviceId\": \"GANTI_DENGAN_ID_PERANGKAT_ANDA\",\n  \"forward\": 15.5,\n  \"backward\": 0.0,\n  \"cumulative\": 210.5\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/v1/iot/water-usage",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "iot",
            "water-usage"
          ]
        }
      }
    },
    {
      "name": "5. Fitur Melihat Dashboard",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/dashboard/chart?range=Mingguan",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "dashboard",
            "chart"
          ],
          "query": [
            {
              "key": "range",
              "value": "Mingguan"
            }
          ]
        }
      }
    },
    {
      "name": "6. Fitur Menghitung Tagihan",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"deviceId\": \"GANTI_DENGAN_ID_PERANGKAT_ANDA\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/v1/billing/generate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "billing",
            "generate"
          ]
        }
      }
    },
    {
      "name": "7. Fitur Melakukan Pembayaran",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"billId\": \"GANTI_DENGAN_ID_TAGIHAN_DARI_FITUR_6\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/v1/payment/create",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "payment",
            "create"
          ]
        }
      }
    },
    {
      "name": "8. Fitur Verifikasi Pembayaran (Webhook)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-callback-token",
            "value": "GANTI_DENGAN_TOKEN_XENDIT",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"GANTI_DENGAN_EXTERNALID_DARI_FITUR_7\",\n  \"status\": \"PAID\",\n  \"amount\": 12500\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/v1/payment/webhook",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "payment",
            "webhook"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "MASUKKAN_TOKEN_LOGIN_DI_SINI",
      "type": "string"
    }
  ]
}
